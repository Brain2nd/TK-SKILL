{
  "name": "kol-crm",
  "version": "1.0.0",
  "description": "KOL CRM outreach automation — plain Node.js modules",
  "type": "module",
  "scripts": {
    "outreach:setup": "node setup_first_outreach_fields.mjs",
    "outreach": "node auto_outreach.mjs --dry-run",
    "outreach:approve": "node approve_outreach_batch.mjs",
    "outreach:execute": "node auto_outreach.mjs --execute",
    "outreach:preview-analyzer": "node preview_analyzer_batch.mjs",
    "outreach:monitor": "node first_outreach_monitor.mjs --dry-run",
    "outreach:monitor:execute": "node first_outreach_monitor.mjs --execute",
    "outreach:reconcile": "node reconcile_outreach.mjs",
    "outreach:reconcile:execute": "node reconcile_outreach.mjs --execute",
    "outreach:resolve-delivery": "node resolve_delivery_unknown.mjs",
    "monitor": "node first_outreach_monitor.mjs --dry-run",
    "monitor:legacy": "node auto_reply_monitor.mjs",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.71.1",
    "imapflow": "^1.4.7",
    "mailparser": "^3.9.14",
    "nodemailer": "^9.0.3"
  }
}
