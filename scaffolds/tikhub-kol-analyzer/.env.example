# Copy this file to .env and fill in your own keys
# Then run:  source .env

export ANTHROPIC_API_KEY=""
# Or use DeepSeek through its Anthropic-compatible API:
# export DEEPSEEK_API_KEY=""
# export LLM_PROVIDER="deepseek"
# export DEEPSEEK_MODEL="deepseek-v4-flash"
# Optional legacy-script default. The Agent search workflow asks for a per-call key.
export TIKHUB_API_KEY=""

# Feishu Base is the shared creator database. The app must have Base read/write
# permission and be added as a collaborator to the target Base.
export FEISHU_APP_ID=""
export FEISHU_APP_SECRET=""
export FEISHU_BITABLE_APP_TOKEN=""
export FEISHU_BITABLE_TABLE_ID=""
export FEISHU_BITABLE_UNIQUE_FIELD="username"
# Set true if a Base sync failure must fail the whole pipeline.
export FEISHU_BITABLE_STRICT="false"
